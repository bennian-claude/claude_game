rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /balloon_shooter/{doc} {
      allow read: if true;
      allow create: if request.resource.data.name is string &&
                       request.resource.data.name.size() <= 20 &&
                       request.resource.data.score is number;
    }
    match /rhythm_game/{doc} {
      allow read: if true;
      allow create: if request.resource.data.name is string &&
                       request.resource.data.name.size() <= 20 &&
                       request.resource.data.score is number;
    }
    match /zombie_hunter/{doc} {
      allow read: if true;
      allow create: if request.resource.data.name is string &&
                       request.resource.data.name.size() <= 20 &&
                       request.resource.data.score is number &&
                       request.resource.data.kills is number;
    }
    match /cyber_tetris/{doc} {
      allow read: if true;
      allow create: if request.resource.data.name is string &&
                       request.resource.data.name.size() <= 20 &&
                       request.resource.data.score is number &&
                       request.resource.data.lines is number &&
                       request.resource.data.level is number;
    }
  }
}
